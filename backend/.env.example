# Port (nginx: admin.quietchat.in/api → Node on 5000)
PORT=5000

# Project name
projectName=Quiet Chat

# Secret key for JWT (use a long random string in production)
JWT_SECRET=replace-with-a-strong-random-secret

# Secret key for API (must match admin frontend key where used)
secretKey=replace-with-your-api-secret

# Public server URL
baseURL=https://admin.quietchat.in

# MongoDB connection string (user:password@host:port/database?options)
MongoDb_Connection_String=mongodb://USER:PASSWORD@HOST:27017/quietchat?authSource=admin
